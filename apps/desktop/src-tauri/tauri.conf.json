{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "毅研每日一题生成器",
  "version": "0.1.0",
  "identifier": "com.yiyan.daily-question-generator",
  "build": {
    "beforeDevCommand": "npm run vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run vite:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "毅研每日一题生成器",
        "width": 1180,
        "height": 780,
        "minWidth": 920,
        "minHeight": 620,
        "resizable": true,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob:; font-src 'self' data:; connect-src 'self' http://127.0.0.1:* http://localhost:*; object-src 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
